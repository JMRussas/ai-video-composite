{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Scene Config",
    "description": "Configuration for multi-layer video compositing via the video-layers command.",
    "type": "object",
    "required": ["background", "layers"],
    "properties": {
        "name": {
            "type": "string",
            "description": "Human-readable scene name (used in log output)."
        },
        "background": {
            "type": "string",
            "description": "Path to background image or video (relative to this JSON file)."
        },
        "audio": {
            "type": "string",
            "enum": ["auto", "mix", "none"],
            "default": "auto",
            "description": "Audio mode: 'auto' uses first layer with audio=true, 'mix' mixes all layers, 'none' strips audio."
        },
        "layers": {
            "type": "array",
            "minItems": 1,
            "description": "Video layers rendered bottom-to-top (first = closest to background).",
            "items": {
                "type": "object",
                "required": ["video"],
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "Human-readable layer name (used in log output)."
                    },
                    "video": {
                        "type": "string",
                        "description": "Path to video file (relative to this JSON file)."
                    },
                    "position": {
                        "type": "string",
                        "default": "center",
                        "description": "Horizontal position: 'left' (15%), 'center' (50%), 'right' (85%), or 'x,y' pixels."
                    },
                    "scale": {
                        "type": "number",
                        "default": 0.75,
                        "minimum": 0.01,
                        "maximum": 2.0,
                        "description": "Layer height as fraction of background height."
                    },
                    "offset_x": {
                        "type": "integer",
                        "default": 0,
                        "description": "Horizontal pixel offset (positive = right)."
                    },
                    "offset_y": {
                        "type": "integer",
                        "default": 0,
                        "description": "Vertical pixel offset from bottom (positive = up)."
                    },
                    "chromakey": {
                        "type": "boolean",
                        "default": true,
                        "description": "Apply chromakey green-screen removal to this layer."
                    },
                    "chroma_color": {
                        "type": "string",
                        "default": "0x00b140",
                        "description": "Chromakey color in FFmpeg hex format."
                    },
                    "similarity": {
                        "type": "number",
                        "default": 0.3,
                        "minimum": 0.01,
                        "maximum": 1.0,
                        "description": "Chromakey color similarity threshold (lower = stricter)."
                    },
                    "blend": {
                        "type": "number",
                        "default": 0.1,
                        "minimum": 0.0,
                        "maximum": 1.0,
                        "description": "Chromakey edge blend amount."
                    },
                    "audio": {
                        "type": "boolean",
                        "default": false,
                        "description": "Include this layer's audio track in the output."
                    }
                }
            }
        }
    }
}
